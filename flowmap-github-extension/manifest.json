{
  "manifest_version": 3,
  "name": "Flowmap for GitHub",
  "version": "1.0",
  "description": "Integrate Flowmap canvas directly into GitHub repository pages.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://github.com/*"],
      "js": ["content-github.js"],
      "run_at": "document_idle"
    }
  ]
}
